# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# --- Supabase ---
# Create a project at https://supabase.com/dashboard, then:
# Project Settings -> API -> Project URL / anon public key / service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key bypasses Row Level Security — server-only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Paymob (Egypt) ---
# Create an account at https://accept.paymob.com (test/sandbox mode available).
# Settings tab -> API Key
PAYMOB_API_KEY=
# Integrations tab -> the id of your card payment integration
PAYMOB_INTEGRATION_ID=
# iFrames tab -> your iframe id
PAYMOB_IFRAME_ID=
# iFrames tab -> your iframe -> HMAC secret (used to verify webhook authenticity)
PAYMOB_HMAC_SECRET=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
